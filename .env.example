# ⚠️ YIELDFARMPAYMENT v1.0 CONFIGURATION TEMPLATE
# Copy this file to .env and update with your values
# v1.0 ONLY supports Upfront Mode (immediate payment + capital recovery)

# ====================================================================
# 🔐 REQUIRED CONFIGURATION
# ====================================================================

# 🔒 Wallet Private Key (MAINNET - KEEP SECURE!)
# ⚠️ NEVER share or commit this to version control
# Generate a new wallet for production use
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# 🌐 Base Network RPC URL
# Mainnet: https://mainnet.base.org
# Sepolia: https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org

# ====================================================================
# 📜 SMART CONTRACT ADDRESSES (Base Mainnet)
# ====================================================================

# 🏦 Aave V3 Contracts (Base Mainnet - Verified)
AAVE_V3_POOL_ADDRESS=0xA238Dd80C259a72e81d7e4664a9801593F98d1c5
POOL_DATA_PROVIDER=0xe20fcbdffc4dd138ce8b2e6fbb6cb49777ad64d
ORACLE_ADDRESS=0x2Cc0Fc26eD4563A5ce5e8bdcfe1A2878676Ae156

# 💰 Token Addresses (Base Mainnet - Verified)
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913        # Circle USDC
USDT_ADDRESS=0xfde4C96c8593536E31F229EA8f37b2ADa2699bb2       # Tether USDT

# 🌀 Aave aToken Addresses (Base Mainnet - Verified)
AAVE_USDC_TOKEN_ADDRESS=0x4e65fE4DbA92790696d040ac24Aa414708F5c0AB  # aBaseUSDC

# 🔄 x402 Streaming Contracts (v2.0 Planned - NOT USED in v1.0)
# X402_STREAM_CONTRACT=0x0000000000000000000000000000000000000000
# X402_STREAM_FACTORY=0x0000000000000000000000000000000000000000

# ====================================================================
# ⚙️ PAYMENT SETTINGS (v1.0 - Upfront Mode Only)
# ====================================================================

# 💸 Skill fee in USDC (per payment)
SKILL_FEE_USDC=0.20

# 🎯 Default Collateral Settings
DEFAULT_COLLATERAL_MULTIPLIER=20      # 20x collateral by default (~1.6 year recovery)
DEFAULT_BUFFER_PERCENTAGE=8           # 8% buffer for safety

# 📏 Safety Limits
MIN_COLLATERAL_MULTIPLIER=3           # Minimum 3x collateral
MAX_COLLATERAL_MULTIPLIER=20          # Maximum 20x collateral
MIN_BUFFER_PERCENTAGE=5               # Minimum 5% buffer
MAX_BUFFER_PERCENTAGE=15              # Maximum 15% buffer

# 🎁 Incentive Structure (v2.0 Planned)
# BUYER_INCENTIVE_PERCENTAGE=1.5        # 1.5% buyer incentive (v2.0)
# NET_BUYER_INCENTIVE_PERCENTAGE=1.0    # 1.0% net incentive after fees (v2.0)

# 🏥 Aave Health Factor Safety
MIN_HEALTH_FACTOR=2.0                 # Minimum health factor (1.0 = liquidation)

# 📈 Yield Estimation (Conservative)
ESTIMATED_APY=0.03                    # 3% conservative APY for USDC on Aave V3

# ====================================================================
# ⚡ TRANSACTION SETTINGS
# ====================================================================

# ⛽ Gas Settings
MAX_GAS_PRICE_GWEI=100                # Maximum gas price in Gwei
GAS_PRICE_MONITORING=true             # Monitor gas prices
GAS_PRICE_THRESHOLD=30                # Gas price threshold in Gwei
GAS_PRICE_MULTIPLIER=1.5              # Multiplier for retry attempts

# 🔄 Transaction Retry Settings
TRANSACTION_RETRY_COUNT=5             # Number of retry attempts
TRANSACTION_TIMEOUT_SECONDS=180       # Transaction timeout
RPC_TIMEOUT_SECONDS=45                # RPC timeout

# ====================================================================
# 📊 LOGGING & MONITORING
# ====================================================================

LOG_LEVEL=info                        # debug, info, warn, error
ENABLE_TRANSACTION_LOGGING=true       # Log transaction details
ENABLE_PERFORMANCE_METRICS=true       # Collect performance metrics
ENABLE_COLORED_OUTPUT=true            # Colorful console output
ENABLE_PROGRESS_BARS=true             # Show progress bars
VERBOSE_LOGGING=false                 # Verbose logging for debugging

# ====================================================================
# 🧪 TESTING SETTINGS
# ====================================================================

# 📅 Smart Mode Settings (v2.0 Planned)
# MAX_DEADLINE_DAYS=365                 # Maximum deadline for smart mode (v2.0)
# SMART_MODE_MINIMUM_MARGIN_DAYS=3      # Minimum margin days (v2.0)
# SMART_MODE_TARGET_MARGIN_DAYS=7       # Target margin days (v2.0)

# ====================================================================
# 🔧 ADVANCED SETTINGS (Usually don't need to change)
# ====================================================================

# Network chain ID (Base = 8453, Base Sepolia = 84532)
CHAIN_ID=8453

# Aave referral code (0 = no referral)
AAVE_REFERRAL_CODE=0

# x402 streaming parameters (v2.0 Planned)
# X402_STREAM_UPDATE_INTERVAL=86400     # 24 hours in seconds (v2.0)
# X402_MIN_STREAM_AMOUNT=0.001          # Minimum stream amount in USDC (v2.0)

# ====================================================================
# 🚀 QUICK START INSTRUCTIONS
# ====================================================================

# 1. Copy this file to .env
# 2. Update PRIVATE_KEY with your secure wallet key
# 3. Verify contract addresses for your network
# 4. For testnet, use Sepolia addresses and faucets
# 5. Start with small amounts (0.01 USDC) for testing

# ====================================================================
# 🧪 TESTING WORKFLOW
# ====================================================================

# A. Safe simulation (no funds required):
#    node scripts/test-realistic-payment.js
#
# B. Validate configuration:
#    node scripts/check-configuration.js
#
# C. Live testing (with funds):
#    node scripts/cli.js --amount 0.01 --recipient 0x... --collateral 5 --buffer 8
#
# D. Monitor transactions:
#    https://basescan.org

# ====================================================================
# ⚠️ SECURITY WARNING
# ====================================================================

# - NEVER use the same private key for testing and production
# - Generate a dedicated wallet for yield farming operations
# - Store private keys in password managers or hardware wallets
# - Use multi-signature for large amounts
# - Test thoroughly on testnet before mainnet deployment