# 🌾 YieldFarmPayment v2.0 — Configuration Template
# Copy this file to .env and replace placeholder values

# ====================================================================
# 🔐 REQUIRED SETTINGS (MUST BE UPDATED)
# ====================================================================

# 🌐 WalletConnect v2.0 Project ID (FREE - REQUIRED)
# 🔗 Get from: https://cloud.walletconnect.com (sign up → create project)
# ⚠️ Replace with your FREE project ID
WALLETCONNECT_PROJECT_ID=your_project_id_here

# 🌐 Base Network RPC URL
# Mainnet: https://mainnet.base.org (default)
# Alternative RPCs: https://docs.base.org/network-information
BASE_RPC_URL=https://mainnet.base.org

# ====================================================================
# 🏗️ BASE MAINNET CONTRACT ADDRESSES (VERIFIED)
# ====================================================================

# 💰 USDC on Base (Circle) - Verified
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# 🏦 Aave V3 Pool (Base Mainnet) - Verified
AAVE_V3_POOL_ADDRESS=0xA238Dd80C259a72e81d7e4664a9801593F98d1c5

# Optional: Additional contract addresses (for reference)
POOL_DATA_PROVIDER=0xe20fcbdffc4dd138ce8b2e6fbb6cb49777ad64d
ORACLE_ADDRESS=0x2Cc0Fc26eD4563A5ce5e8bdcfe1A2878676Ae156
AAVE_USDC_TOKEN_ADDRESS=0x4e65fE4DbA92790696d040ac24Aa414708F5c0AB

# ====================================================================
# ⚙️ PAYMENT SETTINGS (v2.0 - WalletConnect + HTML)
# ====================================================================

# 💸 Skill fee in USDC (per transaction - visible before signing)
SKILL_FEE_USDC=0.2

# 🎯 Default Collateral Multiplier (when not specified)
DEFAULT_COLLATERAL_MULTIPLIER=20

# 🔒 Default Buffer Percentage (safety margin)
DEFAULT_BUFFER_PERCENTAGE=8

# ====================================================================
# 📏 SAFETY LIMITS
# ====================================================================

# Minimum collateral multiplier (for safety)
MIN_COLLATERAL_MULTIPLIER=3

# Maximum collateral multiplier (risk management)
MAX_COLLATERAL_MULTIPLIER=20

# Minimum buffer percentage (extra safety)
MIN_BUFFER_PERCENTAGE=5

# Maximum buffer percentage (capital efficiency)
MAX_BUFFER_PERCENTAGE=15

# ====================================================================
# 📈 YIELD ESTIMATION
# ====================================================================

# Estimated Annual Percentage Yield for USDC on Aave V3
# Conservative estimate (real yield may vary)
ESTIMATED_APY=0.03

# ====================================================================
# ⚡ TRANSACTION SETTINGS
# ====================================================================

# Base Mainnet Chain ID (don't change unless testing)
CHAIN_ID=8453

# Transaction timeout in seconds (adjust as needed)
TRANSACTION_TIMEOUT_SECONDS=180

# RPC timeout in seconds (network responsiveness)
RPC_TIMEOUT_SECONDS=45

# Maximum gas price in Gwei (safety limit)
MAX_GAS_PRICE_GWEI=100

# ====================================================================
# 📊 LOGGING & MONITORING
# ====================================================================

# Log level: debug, info, warn, error (info for production)
LOG_LEVEL=info

# Enable colorful console output (true for better UX)
ENABLE_COLORED_OUTPUT=true

# Show progress bars during execution
ENABLE_PROGRESS_BARS=true

# Log transaction details (helpful for debugging)
ENABLE_TRANSACTION_LOGGING=true

# ====================================================================
# 🚀 QUICK SETUP GUIDE
# ====================================================================

# ⭐⭐ STEP 1: GET WALLETCONNECT PROJECT ID (FREE) ⭐⭐
#
# 1. Visit: https://cloud.walletconnect.com
# 2. Sign up (free account, email verification)
# 3. Click "New Project"
# 4. Enter project name (e.g., "YieldFarmPayment")
# 5. Copy "Project ID" (looks like: abc123def456...)
# 6. Paste below replacing "your_project_id_here"
#
# WALLETCONNECT_PROJECT_ID=your_project_id_here

# ⭐ STEP 2: COPY AND CONFIGURE
#
# 1. Copy this file: cp .env.example .env
# 2. Edit .env: nano .env (or your favorite editor)
# 3. Replace WALLETCONNECT_PROJECT_ID with your ID
# 4. Save and exit

# ⭐ STEP 3: VERIFY SETUP
#
# Run: node scripts/check-configuration.js
#
# Should show "✅ Ready for production!"

# ⭐ STEP 4: TEST DRY-RUN
#
# Always test with --dry-run first:
# node scripts/cli-wc2.js --dry-run --amount 0.01 --recipient 0x...

# ====================================================================
# 🎯 EXECUTION MODES
# ====================================================================

# 📱 WalletConnect Mode (QR code - recommended):
# node scripts/cli-wc2.js --walletconnect --amount 0.1 --recipient 0x...
#
# Flow: Terminal shows QR code → Scan with mobile wallet → Sign 3 transactions

# 🌐 HTML Wallet Mode (browser - user-friendly):
# node scripts/cli-final.js --html-wallet --amount 0.1 --recipient 0x...
#
# Flow: CLI generates HTML → Open in browser → Connect wallet → Sign

# 📄 Manual Mode (advanced - for Revoke.cash):
# node scripts/cli-wc2.js --manual --amount 0.1 --recipient 0x...
#
# Flow: Save transactions as JSON → Import to Revoke.cash → Execute batch

# ====================================================================
# 📚 COMMAND REFERENCE
# ====================================================================

# Check configuration:      node scripts/check-configuration.js
# Calculate optimal collateral: node scripts/collateral-calculator.js --amount 0.1 --deadline 90
# Run test suite:          node scripts/test-realistic-payment.js
# WalletConnect CLI help:  node scripts/cli-wc2.js --help
# HTML Wallet CLI help:    node scripts/cli-final.js --help
# NPM scripts:             npm run check, npm run test, npm run calc

