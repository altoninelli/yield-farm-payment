# .gitignore for YieldFarmPayment
# ================================
# Environment variables and sensitive data
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.backup
.env.*.backup

# Secrets and private keys
*.pem
*.key
*.secret
secrets/
private/
config/private*.json

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build outputs
dist/
build/
.coverage/
.nyc_output/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# OS generated files
ehthumbs.db
Desktop.ini

# Logs
logs/
*.log

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Package manager specific
package-lock.json
yarn.lock
pnpm-lock.yaml

# Testing
coverage/
.nyc_output/

# Documentation excluded from public repo
/references/v2.0-planned/

# Local development files
.local-*
