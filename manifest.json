{
  "name": "YieldFarmPayment",
  "version": "1.0.0",
  "description": "DeFi Yield Farming Payment System with Flexible Collateral",
  "author": "YieldFarmPayment Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/yield-farm-payment.git"
  },
  "keywords": [
    "defi",
    "yield-farming",
    "aave",
    "base",
    "payments",
    "collateral",
    "streaming"
  ],
  "categories": ["defi", "payments", "yield-farming"],
  "compatibility": {
    "openclaw": ">=1.0.0",
    "node": ">=18.0.0"
  },
  "dependencies": [
    "viem",
    "dotenv"
  ],
  "files": [
    "SKILL.md",
    "README.md",
    "manifest.json",
    "package.json",
    ".env.example",
    "scripts/",
    "references/"
  ],
  "entrypoints": {
    "cli": "scripts/cli.js",
    "main": "scripts/yield-farm-payment.js",
    "test": "scripts/test-realistic-payment.js"
  },
  "configuration": {
    "required": ["PRIVATE_KEY", "BASE_RPC_URL"],
    "optional": {
      "AAVE_V3_POOL_ADDRESS": "0x794a61358D6845594F94dc1DB02A252b5b4814aD",
      "USDC_ADDRESS": "0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913",
      "SKILL_FEE_USDC": 0.15,
      "DEFAULT_COLLATERAL_MULTIPLIER": 10,
      "DEFAULT_BUFFER_PERCENTAGE": 8
    }
  },
  "commands": {
    "payment": "node scripts/cli.js --amount <amount> --recipient <address> [--mode <mode>] [--collateral <multiplier>] [--buffer <percentage>]",
    "calculate": "node scripts/collateral-calculator.js --amount <amount> --deadline <days>",
    "check": "node scripts/check-configuration.js",
    "test": "node scripts/test-realistic-payment.js"
  },
  "examples": [
    {
      "description": "Standard payment with 1 USDC",
      "command": "node scripts/cli.js --amount 1 --recipient 0x... --collateral 10 --buffer 8"
    },
    {
      "description": "Smart mode with 180-day deadline",
      "command": "node scripts/cli.js --mode smart --amount 10 --recipient 0x... --deadline 180 --buffer 12"
    },
    {
      "description": "Upfront immediate payment",
      "command": "node scripts/cli.js --mode upfront --amount 0.5 --recipient 0x... --collateral 3 --buffer 5"
    }
  ],
  "networkSupport": ["base", "base-sepolia"],
  "protocols": ["aave-v3", "erc20"],
  "features": [
    "flexible-collateral",
    "yield-streaming",
    "deadline-optimization",
    "transaction-retry",
    "health-monitoring"
  ],
  "screenshots": [],
  "tags": ["defi", "payments", "yield", "collateral", "aave", "base"],
  "links": {
    "documentation": "SKILL.md",
    "github": "https://github.com/yourusername/yield-farm-payment",
    "issues": "https://github.com/yourusername/yield-farm-payment/issues"
  }
}