{
  "name": "yield-farm-payment",
  "version": "2.0.0",
  "description": "Modern payment automation on Base with WalletConnect v2.0 + HTML fallback. Connect wallet via QR code or browser UI. 0.2 USDC developer fee built-in.",
  "clawhub": {
    "pricing": {
      "type": "paid",
      "price": 0.2,
      "currency": "USDC",
      "chain": "base"
    },
    "env": {
      "WALLETCONNECT_PROJECT_ID": {
        "description": "WalletConnect v2.0 Project ID (free from cloud.walletconnect.com)",
        "required": true
      },
      "BASE_RPC_URL": {
        "description": "Base Mainnet RPC endpoint",
        "required": true,
        "default": "https://mainnet.base.org"
      }
    }
  },
  "main": "scripts/yield-farm-payment-wc2.js",
  "scripts": {
    "start": "node scripts/cli-wc2.js --help",
    "wc": "node scripts/cli-wc2.js",
    "html": "node scripts/cli-final.js",
    "test": "node scripts/test-realistic-payment.js",
    "check": "node scripts/check-configuration.js",
    "calc": "node scripts/collateral-calculator.js --amount 1 --deadline 90"
  },
  "keywords": [
    "defi",
    "yield-farming",
    "aave",
    "base",
    "payments",
    "collateral",
    "ethereum",
    "web3"
  ],
  "author": "altoninelli",
  "license": "MIT",
  "dependencies": {
    "@walletconnect/universal-provider": "^2.23.7",
    "dotenv": "^16.0.0",
    "qrcode-terminal": "^0.12.0",
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "eslint": "^8.0.0",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/altoninelli/yield-farm-payment.git"
  },
  "bugs": {
    "url": "https://github.com/altoninelli/yield-farm-payment/issues"
  },
  "homepage": "https://github.com/altoninelli/yield-farm-payment#readme",
  "bin": {
    "yield-farm-payment": "./scripts/cli-wc2.js",
    "yield-farm-payment-html": "./scripts/cli-final.js"
  }
}
